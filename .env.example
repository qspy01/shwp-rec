# Database
DATABASE_URL=postgresql://postgres:SecurePassword123!@localhost:5435/shwprec

# Redis
REDIS_HOST=localhost
REDIS_PORT=6385
REDIS_PASSWORD=

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=http://localhost:9005
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123
MINIO_BUCKET=vods

# Workers
CAPTURE_DIR=/tmp/shwp/captures
WORKER_CONCURRENCY=2
MAX_FFMPEG_CONCURRENCY=2

# Services
# URL of service-scheduler (for Next.js admin queue proxy)
SCHEDULER_URL=http://localhost:3001

# Internal service authentication (used for future ingest auth)
INGEST_SERVICE_SECRET=change-me-strong-random-secret

# Authentication (web app)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-32-byte-random-hex-string
# Provide this header value to POST /api/auth/register to create an ADMIN account
# Leave unset to allow only VIEWER registrations
ADMIN_REGISTRATION_SECRET=change-me-strong-admin-secret

# Runtime
NODE_ENV=development
