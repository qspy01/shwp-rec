# Database
DATABASE_URL=postgresql://shwp:shwp@localhost:5432/shwp

# Redis
REDIS_URL=redis://localhost:6379

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=shwp-recordings
R2_PUBLIC_URL=https://your-r2-public-url.com

# API
API_PORT=3001
INGEST_SERVICE_SECRET=change-me-strong-random-secret

# Sentry
SENTRY_DSN=

# Workers
CAPTURE_DIR=/tmp/shwp/captures
WORKER_CONCURRENCY=2
MAX_FFMPEG_CONCURRENCY=2
API_URL=http://localhost:3001/api/v1
